AZURE_SUBSCRIPTION_ID="<your_subscription_id>"
AZURE_TENANT_ID="<your_tenant_id>"

# Azure deployment
LOCATION="japaneast"
ENVIRONMENT_NAME="dev"
NAME_PREFIX="aidinner"
DEPLOYMENT_NAME="aidinner-dev"
RESOURCE_GROUP="rg-aidinner-dev-japaneast"
ACR_NAME="<your_acr_name>"
ACR_LOGIN_SERVER="<your_acr_login_server>"
CONTAINER_APP_NAME="<your_container_app_name>"

# FastAPI / local development
APP_ENV="dev"
MENU_DATA_PATH="data/menu.json"
USE_COSMOS="true"
PYTHONPATH="."

# Azure Cosmos DB for NoSQL
COSMOS_ACCOUNT_NAME="<your_cosmos_account_name>"
COSMOS_ENDPOINT="<your_cosmos_endpoint>"
COSMOS_DATABASE_NAME="dinner-planner"
COSMOS_CONTAINER_NAME="menus"

# Microsoft Foundry Hosted Agent
FOUNDRY_ACCOUNT_NAME="<your_foundry_account_name>"
FOUNDRY_PROJECT_NAME="<your_foundry_project_name>"
FOUNDRY_PROJECT_ENDPOINT="<your_foundry_project_endpoint>"
FOUNDRY_AGENT_NAME="ai-dinner-planner"
AZURE_AI_MODEL_DEPLOYMENT_NAME="gpt-5.4-mini"
HOSTED_AGENT_PRINCIPAL_ID="<your_hosted_agent_principal_id>"